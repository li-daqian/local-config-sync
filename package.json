{
  "name": "local-config-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "pnpm -r --filter './packages/{core,cli}' build",
    "local-config": "node packages/cli/dist/cli.js",
    "test": "vitest run",
    "typecheck": "pnpm --filter @local-config-sync/core build && pnpm -r --filter './packages/{core,cli}' typecheck",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "plugin:build": "packages/jetbrains/gradlew -p packages/jetbrains buildPlugin",
    "plugin:check": "packages/jetbrains/gradlew -p packages/jetbrains verifyPluginProjectConfiguration verifyPluginStructure buildPlugin",
    "plugin:verify": "packages/jetbrains/gradlew -p packages/jetbrains verifyPluginProjectConfiguration verifyPluginStructure verifyPlugin"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
